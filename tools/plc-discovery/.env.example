# Conexión al servidor OPC UA (FactoryTalk Optix)
# El servidor anuncia internamente 10.10.51.225 pero el acceso real es la IP pública:
OPC_ENDPOINT=opc.tcp://181.204.165.66:59100

# Credenciales (solo si el preflight indica que Anonymous no está habilitado)
# OPC_USERNAME=
# OPC_PASSWORD=

# Ruta raíz del descubrimiento (separada por "/")
# OPC_ROOT_PATH=AQUATECH/CommDrivers/RAEtherNet_IPDriver1/RAEtherNet_IPStation1/Tags/Controller Tags

# Ajustes de cortesía hacia el HMI de producción
# DISCOVERY_THROTTLE_MS=100
# DISCOVERY_BROWSE_BATCH=20
# DISCOVERY_READ_BATCH=100
# DISCOVERY_SAMPLE_COUNT=3
# DISCOVERY_SAMPLE_INTERVAL_MS=45000
# DISC_MAX_NODES=20000
