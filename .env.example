PASSWORD_PEPPER_CURRENT_VERSION=1
PASSWORD_PEPPER_V1_BASE64=

# Generate PASSWORD_PEPPER_V1_BASE64 with:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"

# Puerto del backend @ptap/api (default 4000)
PORT=4000

# MySQL (backend @ptap/api). DB_PASSWORD entre comillas dobles si contiene @ o #.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=monitor_ptap

# ── Gateway OPC UA (Fase 1) ────────────────────────────────────────────────
# Selección de adaptador del puente crudo: simulator | opcua
CONNECTIVITY_PROVIDER=simulator

# Conexión al servidor OPC UA (FactoryTalk Optix). El server se anuncia con IP
# interna 10.10.51.225 → endpointMustExist=false (default).
OPC_ENDPOINT=opc.tcp://181.204.165.66:59100
OPC_ENDPOINT_MUST_EXIST=false
# Seguridad: None | Sign | SignAndEncrypt  ×  None | Basic256Sha256 | Aes128_Sha256_RsaOaep | Aes256_Sha256_RsaPss
# Hoy el server acepta None+Anonymous (hallazgo P0). Conmutar a seguro solo por .env (Fase 4).
OPC_SECURITY_MODE=None
OPC_SECURITY_POLICY=None
# Identidad: anonymous | username | certificate (username requiere OPC_USERNAME/OPC_PASSWORD;
# certificate usa el certificado propio del cliente que OPCUACertificateManager autogenera en
# pki/own/certs/client_certificate.pem — ver docs/OPTIX_CLIENT_CERT_TRUST.md).
OPC_IDENTITY=anonymous
# OPC_USERNAME=
# OPC_PASSWORD=
# true SOLO para desarrollo/bootstrap contra el simulador o un servidor de pruebas local. En
# producción contra el servidor de la planta debe quedar false (confiar el certificado del
# servidor manualmente moviéndolo de pki/rejected a pki/trusted tras verificarlo).
OPC_AUTO_ACCEPT_UNKNOWN_CERTIFICATE=false

# Subscription y resiliencia (es una PTAP, no un servo)
OPCUA_PUBLISHING_INTERVAL_MS=2000
OPCUA_SAMPLING_INTERVAL_MS=1000
# Vida de la Subscription (múltiplos de publishingInterval). REGLA DURA: lifetime >= 3 ×
# keepalive (OPC UA Part 4). Si no se cumple, el backend NO arranca.
OPCUA_REQUESTED_LIFETIME_COUNT=100
OPCUA_REQUESTED_MAX_KEEPALIVE_COUNT=10
# Ventana de coalescing: UN RawPlantFrame por planta por ventana (nunca uno por buffer).
# Default = publishingInterval. Con jitter puede fusionar dos ciclos (last-wins por buffer,
# coherente con queueSize:1); bajarla por debajo de publishingInterval si se necesita 1 frame/ciclo estricto.
OPCUA_COALESCE_WINDOW_MS=2000
OPCUA_WATCHDOG_TIMEOUT_MS=30000
OPCUA_HEARTBEAT_INTERVAL_MS=10000
# Fallos de heartbeat CONSECUTIVOS que fuerzan Connected → Recovering (y reciclaje de sesión).
OPCUA_HEARTBEAT_MAX_FAILURES=2
OPCUA_RECONNECT_INITIAL_DELAY_MS=1000
OPCUA_RECONNECT_MAX_DELAY_MS=30000
# Reintentos de reconexión de node-opcua (efectivamente indefinido: el operador restaura la red sin reiniciar).
OPCUA_RECONNECT_MAX_RETRY=1000000
OPCUA_SUBSCRIPTION_RECYCLE_MAX_ATTEMPTS=3
# Umbral de frescura de datos para connectionStatus (FASE 0.3): 5 min
OPCUA_STALE_THRESHOLD_MS=300000
# Escritura al PLC (Fase 5): prohibida por defecto
OPCUA_WRITES_ENABLED=false
# OPC_MAPPING_PATH=  # opcional; default config/opc_mapping.json

# ── Liveness del pipeline de dominio (connectionStatus por frescura, PASO 3.3) ──
# live si hubo un cambio en los últimos LIVENESS_LIVE_SEC; stale si no hubo en LIVENESS_WINDOW_SEC.
LIVENESS_LIVE_SEC=10
LIVENESS_WINDOW_SEC=300
# Cada cuánto se re-evalúa el liveness (para pasar idle→stale sin frames nuevos).
LIVENESS_SWEEP_MS=2000

# ── Fase 4: Autenticación (JWT) ──────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=8h
# Semilla del primer usuario admin. Solo los lee scripts/seed-admin-user.ts (no el runtime).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
SEED_ADMIN_PLANT=

# ── Fase 4: Auditoría (MySQL, tabla audit_log) ───────────────────────────
# Trunca el campo `detail` (JSON) a este tamaño en bytes antes de persistir.
AUDIT_LOG_DETAIL_MAX_BYTES=4096

# ── Fase 4: Métricas Prometheus ──────────────────────────────────────────
# Token opcional para proteger /metrics (Bearer). Vacío = /metrics abierto (estándar de scraping).
METRICS_AUTH_TOKEN=

# ── Fase 4: Endurecimiento HTTP ───────────────────────────────────────────
# Orígenes CORS permitidos, separados por coma. Vacío = CORS deshabilitado (solo same-origin/nativo).
# ⚠️ La app web de Expo corre en http://localhost:8081 y llama al backend en :4000 → cross-origin.
# Si dejas esto vacío, el NAVEGADOR bloquea el login contra `npm run dev:api` (curl NO lo detecta,
# porque curl no aplica CORS). Para desarrollo con la web, define:
CORS_ORIGINS=http://localhost:8081
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
# Límite más estricto específico de /api/auth/login (mitiga fuerza bruta).
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=10
