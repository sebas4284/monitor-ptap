{
  "name": "@ptap/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:mapping": "tsx scripts/generate-mapping.ts",
    "validate:mapping": "tsx scripts/validate-mapping.ts",
    "test:mapping": "node --import tsx --test test/opc-mapping.test.ts test/resolve-namespaces.test.ts",
    "test:bridge": "node --import tsx --test test/bridge.test.ts",
    "test": "echo \"No tests configured for @ptap/api\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "@ptap/shared": "*",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "mysql2": "^3.22.6",
    "node-opcua": "^2.175.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.2.1",
    "ajv": "^8.17.1",
    "tsx": "^4.20.3"
  }
}
