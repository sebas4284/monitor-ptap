{
  "name": "@ptap/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "start:telemetry": "tsx src/main.telemetry.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:mapping": "tsx scripts/generate-mapping.ts && tsx scripts/generate-catalog.ts",
    "generate:catalog": "tsx scripts/generate-catalog.ts",
    "validate:mapping": "tsx scripts/validate-mapping.ts",
    "test:mapping": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/opc-mapping.test.ts test/resolve-namespaces.test.ts",
    "test:bridge": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/bridge.test.ts test/frame-coalescer.test.ts test/heartbeat-monitor.test.ts test/connectivity-config.test.ts",
    "test:pipeline": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/pipeline.test.ts",
    "test:auth": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/jwt-auth.guard.test.ts test/rbac-e2e.test.ts",
    "test:health": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/opc-health.test.ts",
    "test:metrics": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/metrics.test.ts",
    "test:audit": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/audit-log.test.ts",
    "test:security": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/opcua-security-switch.test.ts",
    "test": "set \"TSX_TSCONFIG_PATH=tsconfig.test.json\"&& node --import tsx --test test/bridge.test.ts test/frame-coalescer.test.ts test/heartbeat-monitor.test.ts test/connectivity-config.test.ts test/pipeline.test.ts test/opc-mapping.test.ts test/resolve-namespaces.test.ts test/read-opcua-node.test.ts test/jwt-auth.guard.test.ts test/rbac-e2e.test.ts test/opc-health.test.ts test/metrics.test.ts test/audit-log.test.ts test/opcua-security-switch.test.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed-admin": "tsx scripts/seed-admin-user.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/websockets": "^11.1.28",
    "@ptap/shared": "*",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.6",
    "node-opcua": "^2.175.0",
    "node-opcua-crypto": "^4.16.0",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.2.1",
    "@types/supertest": "^6.0.2",
    "ajv": "^8.17.1",
    "supertest": "^7.0.0",
    "tsx": "^4.20.3"
  }
}
